# Server
PORT=4000

# Supabase — source of truth
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the service_role key on the server (never expose it to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# bcrypt
BCRYPT_SALT_ROUNDS=10

# JWT
# Generate a strong secret, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=your-jwt-secret
# Short-lived access token; clients refresh it with the refresh token.
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# Password reset
PASSWORD_RESET_TTL_MINUTES=60
# Base URL (deployed frontend) used to build the reset link in the reset email.
APP_BASE_URL=https://your-frontend.vercel.app

# CORS: comma-separated allowed origins for browser clients. Leave blank to
# reflect any origin (dev). In prod, list your frontend origin(s).
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:4000

# Email (Resend) — get a key at https://resend.com (Settings > API Keys).
# If RESEND_API_KEY is left blank, reset links are logged to the console instead.
# MAIL_FROM must use a verified domain; onboarding@resend.dev works for testing.
RESEND_API_KEY=
MAIL_FROM=Whamr <onboarding@resend.dev>
